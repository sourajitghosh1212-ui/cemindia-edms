<!DOCTYPE html>
<html>
<head>

<title>Revision History</title>

<link rel="stylesheet" href="/style.css">

</head>

<body>

<div class="header">

Revision History

</div>

<div class="content">

<h2>Document: <%= docNo %></h2>

<table border="1" cellpadding="10">

<tr>
<th>Revision</th>
<th>Status</th>
<th>Revision Date</th>
<th>Uploaded By</th>
<th>Remarks</th>
<th>Download</th>
</tr>

<% revisions.forEach(doc => { %>

<tr>

<td><%= doc.revision %></td>

<td><%= doc.status %></td>

<td><%= doc.revisionDate || "-" %></td>

<td><%= doc.uploadedBy || "-" %></td>

<td><%= doc.remarks || "-" %></td>

<td>

<a href="/uploads/<%= doc.filename %>" download>
Download
</a>

</td>

</tr>

<% }) %>

</table>

<br>

<a href="/document-list">
⬅️ Back to Master Document Register
</a>

</div>

</body>
</html>