<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<div class="content">

<div class="container-fluid">

<!-- Page Title -->

<div class="row mb-4">

<div class="col-md-12">

<h2 class="fw-bold text-primary">
📊 Dashboard
</h2>

<p class="text-muted">
Welcome to CEMINDIA Engineering Document Management System
</p>

</div>

</div>

<!-- Statistics -->

<div class="row g-4">

<div class="col-xl-3 col-md-6">

<div class="card bg-primary text-white shadow-lg">

<div class="card-body">

<h6>Total Projects</h6>

<h1><%= totalProjects %></h1>

</div>

</div>

</div>

<div class="col-xl-3 col-md-6">

<div class="card bg-success text-white shadow-lg">

<div class="card-body">

<h6>Total Documents</h6>

<h1><%= totalDocuments %></h1>

</div>

</div>

</div>

<div class="col-xl-3 col-md-6">

<div class="card bg-warning shadow-lg">

<div class="card-body">

<h6>Incoming</h6>

<h1><%= incoming %></h1>

</div>

</div>

</div>

<div class="col-xl-3 col-md-6">

<div class="card bg-info text-white shadow-lg">

<div class="card-body">

<h6>Outgoing</h6>

<h1><%= outgoing %></h1>

</div>

</div>

</div>

<div class="col-xl-3 col-md-6">

<div class="card bg-danger text-white shadow-lg">

<div class="card-body">

<h6>Pending</h6>

<h1><%= pending %></h1>

</div>

</div>

</div>

<div class="col-xl-3 col-md-6">

<div class="card bg-secondary text-white shadow-lg">

<div class="card-body">

<h6>Approved</h6>

<h1><%= approved %></h1>

</div>

</div>

</div>

<div class="col-xl-3 col-md-6">

<div class="card bg-dark text-white shadow-lg">

<div class="card-body">

<h6>Users</h6>

<h1>1</h1>

</div>

</div>

</div>

<div class="col-xl-3 col-md-6">

<div class="card bg-primary text-white shadow-lg">

<div class="card-body">

<h6>Projects Running</h6>

<h1><%= totalProjects %></h1>

</div>

</div>

</div>

</div>

<!-- Chart Starts Here -->
 <div class="row mt-4">

    <div class="col-lg-12">

        <div class="card shadow-lg">

            <div class="card-header bg-dark text-white">

                <h5 class="mb-0">📊 Dashboard Overview</h5>

            </div>

            <div class="card-body">

                <canvas id="statusChart" height="90"></canvas>

            </div>

        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

const ctx = document.getElementById("statusChart");

new Chart(ctx,{

    type:"bar",

    data:{

        labels:[
            "Projects",
            "Documents",
            "Incoming",
            "Outgoing",
            "Pending",
            "Approved"
        ],

        datasets:[{

            label:"Statistics",

            data:[
                <%= totalProjects %>,
                <%= totalDocuments %>,
                <%= incoming %>,
                <%= outgoing %>,
                <%= pending %>,
                <%= approved %>
            ],

            backgroundColor:[
                "#0d6efd",
                "#198754",
                "#ffc107",
                "#0dcaf0",
                "#dc3545",
                "#6c757d"
            ],

            borderRadius:8

        }]

    },

    options:{

        responsive:true,

        plugins:{
            legend:{
                display:false
            }
        },

        scales:{
            y:{
                beginAtZero:true
            }
        }

    }

});

</script>

<!-- Recent Activity Starts -->
 <div class="row mt-4">

    <!-- Recent Documents -->
    <div class="col-lg-4">

        <div class="card shadow-lg">

            <div class="card-header bg-primary text-white">
                📄 Recent Documents
            </div>

            <div class="card-body">

                <table class="table table-striped table-hover">

                    <thead>

                        <tr>
                            <th>Doc No</th>
                            <th>Status</th>
                        </tr>

                    </thead>

                    <tbody>

                        <tr>
                            <td colspan="2" class="text-center">
                                Data will appear here
                            </td>
                        </tr>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

    <!-- Incoming -->
    <div class="col-lg-4">

        <div class="card shadow-lg">

            <div class="card-header bg-success text-white">
                📥 Recent Incoming
            </div>

            <div class="card-body">

                <table class="table table-striped table-hover">

                    <thead>

                        <tr>
                            <th>Document</th>
                            <th>Date</th>
                        </tr>

                    </thead>

                    <tbody>

                        <tr>
                            <td colspan="2" class="text-center">
                                Data will appear here
                            </td>
                        </tr>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

    <!-- Outgoing -->
    <div class="col-lg-4">

        <div class="card shadow-lg">

            <div class="card-header bg-warning">
                📤 Recent Outgoing
            </div>

            <div class="card-body">

                <table class="table table-striped table-hover">

                    <thead>

                        <tr>
                            <th>Document</th>
                            <th>Date</th>
                        </tr>

                    </thead>

                    <tbody>

                        <tr>
                            <td colspan="2" class="text-center">
                                Data will appear here
                            </td>
                        </tr>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<!-- Quick Actions Starts -->
 <div class="row mt-4">

    <!-- Quick Actions -->
    <div class="col-lg-8">

        <div class="card shadow-lg">

            <div class="card-header bg-primary text-white">
                🚀 Quick Actions
            </div>

            <div class="card-body">

                <a href="/projects" class="btn btn-primary m-2">
                    📁 New Project
                </a>

                <a href="/upload" class="btn btn-success m-2">
                    📤 Upload Document
                </a>

                <a href="/incoming" class="btn btn-warning m-2">
                    📥 Incoming
                </a>

                <a href="/outgoing" class="btn btn-info m-2">
                    📤 Outgoing
                </a>

                <a href="/transmittals" class="btn btn-secondary m-2">
                    📨 Transmittals
                </a>

                <a href="/user-management" class="btn btn-danger m-2">
                    👥 Users
                </a>

            </div>

        </div>

    </div>

    <!-- User Panel -->
    <div class="col-lg-4">

        <div class="card shadow-lg">

            <div class="card-header bg-dark text-white">
                👤 Logged In User
            </div>

            <div class="card-body text-center">

                <h4>Administrator</h4>

                <p class="text-muted">
                    Engineering Document Management System
                </p>

                <a href="/logout" class="btn btn-outline-danger">
                    Logout
                </a>

            </div>

        </div>

    </div>

</div>

<hr class="mt-5">

<div class="text-center text-muted mb-4">

<h5>CEMINDIA PROJECTS LIMITED</h5>

<p>Engineering Document Management System (EDMS)</p>

<p>Version 2.0 | © 2026</p>

</div>

</div>

<%- include("partials/footer") %>