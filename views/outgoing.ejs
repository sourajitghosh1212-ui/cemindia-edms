<!DOCTYPE html>
<html>
<head>

<title>Outgoing Document Register</title>

<link rel="stylesheet" href="/css/style.css">

</head>

<body>

<%- include("partials/header") %>

<%- include("partials/sidebar") %>

<div class="content">

<h2>Outgoing Document Register</h2>

<form action="/outgoing" method="POST" enctype="multipart/form-data">

<p>Transmittal Number</p>
<input type="text" name="transmittalNo" required>

<p>Date Sent</p>
<input type="date" name="sentDate" required>

<p>Sent To</p>
<input type="text" name="receiver" required>

<p>Project</p>
<input type="text" name="project" required>

<p>Document Number</p>
<input type="text" name="docNo" required>

<p>Document Title</p>
<input type="text" name="title" required>

<p>Revision</p>
<input type="text" name="revision">

<p>Discipline</p>
<input type="text" name="discipline">

<p>Status</p>

<select name="status">
<option>Submitted</option>
<option>Approved</option>
<option>Rejected</option>
<option>For Review</option>
</select>

<p>Remarks</p>

<textarea name="remarks" rows="4"></textarea>

<p>Upload Document</p>

<input type="file" name="document">

<br><br>

<button type="submit">Save Outgoing Document</button>

</form>

</div>

<%- include("partials/footer") %>

</body>
</html>