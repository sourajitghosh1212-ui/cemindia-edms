<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<div class="content">

<div class="container-fluid mt-4">

<div class="card shadow">

<div class="card-header bg-warning text-dark">

<h3>✏️ Edit Transmittal</h3>

</div>

<div class="card-body">

<form action="/edit-transmittal/<%= transmittal.id %>" method="POST">

<div class="row">

<div class="col-md-6 mb-3">

<label>Transmittal Number</label>

<input
type="text"
name="transmittalNo"
class="form-control"
value="<%= transmittal.transmittalNo %>"
required>

</div>

<div class="col-md-6 mb-3">

<label>Date</label>

<input
type="date"
name="transDate"
class="form-control"
value="<%= transmittal.transDate %>"
required>

</div>

<div class="col-md-6 mb-3">

<label>To Company</label>

<input
type="text"
name="toCompany"
class="form-control"
value="<%= transmittal.toCompany %>"
required>

</div>

<div class="col-md-6 mb-3">

<label>Attention</label>

<input
type="text"
name="attention"
class="form-control"
value="<%= transmittal.attention %>"
required>

</div>

<div class="col-md-12 mb-3">

<label>Subject</label>

<input
type="text"
name="subject"
class="form-control"
value="<%= transmittal.subject %>"
required>

</div>

<div class="col-md-12 mb-3">

<label>Remarks</label>

<textarea
name="remarks"
class="form-control"
rows="4"><%= transmittal.remarks %></textarea>

</div>

<div class="col-md-12">

<button
type="submit"
class="btn btn-success">

💾 Update Transmittal

</button>

<a
href="/transmittal-register"
class="btn btn-secondary">

⬅️ Back

</a>

</div>

</div>

</form>

</div>

</div>

</div>

</div>

<%- include("partials/footer") %>