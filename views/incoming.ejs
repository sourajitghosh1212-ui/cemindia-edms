<!DOCTYPE html>
<html>
<head>

<title>Incoming Document Register</title>

<link rel="stylesheet" href="/css/style.css">

</head>

<body>

<%- include("partials/header") %>

<%- include("partials/sidebar") %>

<div class="content">

<h2>Incoming Document Register</h2>

<form action="/incoming" method="POST" enctype="multipart/form-data">

<p>Transmittal Number</p>
<input type="text" name="transmittalNo" required>

<p>Date Received</p>
<input type="date" name="receivedDate" required>

<p>From</p>
<input type="text" name="from" required>

<p>To</p>
<input type="text" name="to" required>

<p>Project</p>
<input type="text" name="project" required>

<p>Document Number</p>
<input type="text" name="docNo" required>

<p>Document Title</p>
<input type="text" name="title" required>

<p>Revision</p>
<input type="text" name="revision">

<p>Discipline</p>
<input type="text" name="discipline">

<p>Status</p>

<select name="status">

<option>Pending</option>

<option>For Review</option>

<option>Approved</option>

<option>Rejected</option>

</select>

<p>Remarks</p>

<textarea name="remarks" rows="4"></textarea>

<p>Upload Document</p>

<input type="file" name="document">

<br><br>

<button type="submit">Save Incoming Document</button>

</form>

</div>

<%- include("partials/footer") %>

</body>
</html>