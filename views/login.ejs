<!DOCTYPE html>
<html>

<head>

<title>CEMINDIA EDMS Login</title>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

<style>

body{

margin:0;
height:100vh;
display:flex;
justify-content:center;
align-items:center;

background:linear-gradient(135deg,#7f0000,#b71c1c,#d32f2f);

font-family:'Segoe UI',sans-serif;

}

.login-card{

width:430px;

background:#ffffff;

border-radius:18px;

overflow:hidden;

box-shadow:0 15px 35px rgba(0,0,0,.35);

}

.login-header{

background:linear-gradient(90deg,#8B0000,#C62828);

color:white;

padding:30px;

text-align:center;

}

.login-header h2{

font-size:30px;
font-weight:bold;
margin-bottom:8px;

}

.login-header h5{

font-size:16px;
font-weight:300;

}

.card-body{

padding:35px;

background:white;

}

.form-label{

font-weight:600;
color:#8B0000;

}

.form-control{

height:48px;
border-radius:8px;
border:1px solid #ccc;

}

.form-control:focus{

border-color:#C62828;

box-shadow:0 0 8px rgba(198,40,40,.4);

}

.btn-login{

height:50px;

font-size:18px;

font-weight:bold;

background:#C62828;

border:none;

border-radius:8px;

}

.btn-login:hover{

background:#8B0000;

}

.footer{

margin-top:20px;

text-align:center;

font-size:13px;

color:#777;

}

</style>

</head>

<body>

<div class="card login-card">

<div class="login-header">

<h2>CEMINDIA PROJECTS LIMITED</h2>

<h5>Engineering Document Management System</h5>

</div>

<div class="card-body">

<h4 class="text-center mb-4">

<i class="fas fa-user-lock"></i>

Secure Login

</h4>

<form action="/login" method="POST">

<div class="mb-3">

<label class="form-label">

Username

</label>

<input

type="text"

name="username"

class="form-control"

placeholder="Enter Username"

required>

</div>

<div class="mb-4">

<label class="form-label">

Password

</label>

<input

type="password"

name="password"

class="form-control"

placeholder="Enter Password"

required>

</div>

<button

type="submit"

class="btn btn-primary w-100 btn-login">

<i class="fas fa-sign-in-alt"></i>

Login

</button>

</form>

<div class="footer">

© 2026 CEMINDIA Projects Limited

</div>

</div>

</div>

</body>

</html>