<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<div class="content">

<div class="container-fluid mt-4">

<div class="d-flex justify-content-between align-items-center mb-4">

<h2 class="fw-bold text-primary">
📨 Transmittal Register
</h2>

<a href="/transmittals" class="btn btn-primary">
➕ New Transmittal
</a>

</div>

<div class="card shadow">

<div class="card-header bg-dark text-white">

<div class="row">

<div class="col-md-6">

<input
type="text"
class="form-control"
placeholder="Search Transmittal Number or Company">

</div>

<div class="col-md-3">

<input
type="date"
class="form-control">

</div>

<div class="col-md-3 text-end">

<button class="btn btn-success">
Export Excel
</button>

<button class="btn btn-danger">
Export PDF
</button>

</div>

</div>

</div>

<div class="card-body table-responsive">

<table class="table table-bordered table-hover table-striped align-middle">

<thead class="table-primary">

<tr>

<th>Sl No</th>
<th>Transmittal No</th>
<th>Date</th>
<th>Company</th>
<th>Attention</th>
<th>Subject</th>
<th>Remarks</th>
<th>Status</th>
<th width="220">Actions</th>

</tr>

</thead>

<tbody>

<% transmittals.forEach((t,index)=>{ %>

<tr>

<td><%= index+1 %></td>

<td><b><%= t.transmittalNo %></b></td>

<td><%= t.transDate %></td>

<td><%= t.toCompany %></td>

<td><%= t.attention %></td>

<td><%= t.subject %></td>

<td><%= t.remarks %></td>

<td>

<span class="badge bg-success">

Sent

</span>

</td>

<td>

<a href="/edit-transmittal/<%= t.id %>"
class="btn btn-warning btn-sm">
✏️ Edit
</a>

<a href="/delete-transmittal/<%= t.id %>"
class="btn btn-danger btn-sm"
onclick="return confirm('Delete this transmittal?')">
🗑️ Delete
</a>

</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

<div class="card-footer">

<div class="d-flex justify-content-between">

<div>

<b>Total Transmittals :</b>

<span class="badge bg-primary">

<%= transmittals.length %>

</span>

</div>

<div>

<a href="/dashboard"
class="btn btn-secondary">

🏠 Dashboard

</a>

</div>

</div>

</div>

</div>

</div>

</div>

<%- include("partials/footer") %>